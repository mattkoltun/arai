#!/usr/bin/env bash
set -euo pipefail

# ── Only run for Rust/Cargo changes ──────────────────────────────────
if ! git diff-tree --no-commit-id --name-only -r HEAD | grep -qE '^(src/.*\.rs|Cargo\.toml|Cargo\.lock)$'; then
    exit 0
fi

# Guard against infinite loop — the bump commit will also trigger post-commit.
LOCK_FILE="$(git rev-parse --git-dir)/post-commit.lock"
if [[ -f "$LOCK_FILE" ]]; then
    rm -f "$LOCK_FILE"
    exit 0
fi
touch "$LOCK_FILE"

# ── Bump patch version in Cargo.toml ─────────────────────────────────
CARGO_TOML="Cargo.toml"
CURRENT=$(grep '^version' "$CARGO_TOML" | head -1 | sed 's/.*"\(.*\)"/\1/')
IFS='.' read -r MAJOR MINOR PATCH <<< "$CURRENT"
PATCH=$((PATCH + 1))
NEW_VERSION="$MAJOR.$MINOR.$PATCH"

sed -i '' "s/^version = \"$CURRENT\"/version = \"$NEW_VERSION\"/" "$CARGO_TOML"

# Update Cargo.lock to match.
cargo check --quiet 2>/dev/null || true

git add "$CARGO_TOML" Cargo.lock
git commit -m "chore: bump version to v$NEW_VERSION"
